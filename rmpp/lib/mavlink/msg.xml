<?xml version="1.0"?>
<mavlink>
    <version>2</version>
    <messages>
        <message id="0" name="imu">
            <description>imu(c -> pc)</description>
            <field type="float" name="yaw" units="deg">yaw(left is positive)</field>
            <field type="float" name="pitch" units="deg">pitch(up is positive)</field>
            <field type="float" name="roll" units="deg">roll(clockwise is positive)</field>
        </message>

        <message id="1" name="referee">
            <description>referee(c -> pc)</description>
            <field type="uint8_t" name="is_red">is_red</field>
            <field type="uint8_t" name="game_progress">game_progress(see robomaster serial manual)</field>
            <field type="uint16_t" name="stage_remain_time">stage_remain_time(see robomaster serial manual)</field>
            <field type="float" name="bullet_speed" units="m/s">bullet_speed(referee measure value)</field>
        </message>

        <message id="2" name="auto_aim">
            <description>auto_aim(pc -> c)</description>
            <field type="uint8_t" name="is_detect">is_detect</field>
            <field type="float" name="yaw" units="deg">yaw(left is positive)</field>
            <field type="float" name="pitch" units="deg">pitch(up is positive)</field>
            <field type="uint8_t" name="is_fire">is_fire</field>
            <field type="uint8_t" name="robot_id">robot_id(1-7, see robomaster manual)</field>
            <field type="float" name="wr" units="rpm">rpm</field>
            <field type="float" name="distance" units="m">distance</field>
        </message>

        <message id="3" name="ui">
            <description>ui(pc -> c)</description>
            <field type="float" name="x0">x0</field>
            <field type="float" name="y0">y0</field>
            <field type="float" name="x1">x1</field>
            <field type="float" name="y1">y1</field>
            <field type="float" name="x2">x2</field>
            <field type="float" name="y2">y2</field>
            <field type="float" name="x3">x3</field>
            <field type="float" name="y3">y3</field>
        </message>

        <message id="4" name="target_position">
            <description>target_position(c -> pc)</description>
            <field type="float" name="x" units="m">x</field>
            <field type="float" name="y" units="m">y</field>
        </message>

        <message id="5" name="current_position">
            <description>current_position(pc -> c)</description>
            <field type="float" name="x" units="m">x</field>
            <field type="float" name="y" units="m">y</field>
            <field type="float" name="yaw" units="deg">yaw</field>
        </message>

        <message id="6" name="chassis_speed">
            <description>chassis_speed(pc -> c, ref by yaw1)</description>
            <field type="float" name="vx" units="m/s">x</field>
            <field type="float" name="vy" units="m/s">y</field>
        </message>
    </messages>
</mavlink>